# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://vently:vently_dev@localhost:5432/vently?schema=public

# ─── Redis (cache, pub/sub, matchmaking queue, BullMQ) ──────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── WebRTC / TURN (Cloudflare Calls or Metered) ────────────
TURN_PROVIDER=cloudflare
TURN_API_KEY=
TURN_APP_ID=

# ─── AI Ice-breaker (Groq — free at console.groq.com) ───────
# Feature is silently disabled when this key is missing.
GROQ_API_KEY=

# ─── AI Embeddings (Gemini free tier) ───────────────────────
# Used for RAG retrieval. If the key is missing, local-semantic-hash-v1 is used.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── AI Fallback Peer ────────────────────────────────────────
# Pairs users with an ephemeral AI peer when no real match arrives in time.
AI_FALLBACK_ENABLED=false
AI_FALLBACK_MS=8000
# E2E/dev only: bypasses Groq and emits deterministic local AI replies.
AI_FALLBACK_TEST_MODE=false

# ─── Web Push (VAPID) ────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Public key must ALSO be exposed to the client as NEXT_PUBLIC_VAPID_PUBLIC_KEY
# Subject is a contact URL/email so browser push services can reach you
# if your pushes start misbehaving (spec requirement).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@vently.app

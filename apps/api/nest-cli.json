{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      {
        "include": "ai-peer/personas.json",
        "outDir": "dist"
      },
      {
        "include": "ai-peer/tone-packs.json",
        "outDir": "dist"
      },
      {
        "include": "ai-peer/persona-stories.json",
        "outDir": "dist"
      }
    ]
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": ["NODE_ENV", "AI_FALLBACK_ENABLED", "AI_FALLBACK_MS", "AI_FALLBACK_TEST_MODE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"],
      "env": [
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_SOCKET_URL",
        "DATABASE_URL",
        "REDIS_URL",
        "GROQ_API_KEY",
        "AI_FALLBACK_ENABLED",
        "AI_FALLBACK_MS",
        "AI_FALLBACK_TEST_MODE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    }
  }
}
